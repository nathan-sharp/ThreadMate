<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ThreadMate.MainPage"
             Title="ThreadMate">
    <ScrollView>
        <Grid x:Name="MainLayoutGrid"
              Padding="20"
              RowSpacing="14"
              ColumnSpacing="14"
              HorizontalOptions="Center"
              MaximumWidthRequest="1200">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HeaderCard" Grid.Row="0" BackgroundColor="Black" StrokeThickness="0" Padding="14">
                <VerticalStackLayout Spacing="2">
                    <Label Text="ThreadMate" FontSize="28" FontAttributes="Bold" TextColor="White" />
                    <Label x:Name="CalculatorModeLabel" Text="Bolt Thread Calculator" FontSize="16" TextColor="{StaticResource Primary}" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="InputCard" Grid.Row="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Thread Type" FontAttributes="Bold" />
                    <Picker x:Name="ThreadTypePicker" SelectedIndexChanged="OnThreadTypeChanged" />

                    <Label x:Name="MajorDiameterInputLabel" Text="Major Diameter (mm)" FontAttributes="Bold" />
                    <Entry x:Name="MajorDiameterEntry" Placeholder="e.g. 10" Keyboard="Numeric" />

                    <Label x:Name="PitchInputLabel" Text="Pitch (mm)" FontAttributes="Bold" />
                    <Entry x:Name="PitchEntry" Placeholder="e.g. 1.5" Keyboard="Numeric" />

                    <Label x:Name="LengthInputLabel" Text="Threaded Length (mm)" FontAttributes="Bold" />
                    <Entry x:Name="LengthEntry" Placeholder="e.g. 30" Keyboard="Numeric" />

                    <Button Text="Calculate" Clicked="OnCalculateClicked" Margin="0,6,0,0" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ResultsCard" Grid.Row="2" Padding="14" Margin="0,2,0,0">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="StatusLabel" Text="Enter values and tap Calculate." FontAttributes="Italic" />
                    <Label x:Name="PitchDiameterLabel" Text="Pitch Diameter: -" />
                    <Label x:Name="MinorDiameterLabel" Text="Minor Diameter: -" />
                    <Label x:Name="ThreadHeightLabel" Text="Thread Height: -" />
                    <Label x:Name="ThreadsCountLabel" Text="Estimated Threads: -" />
                    <Label x:Name="StressAreaLabel" Text="Tensile Stress Area: -" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
