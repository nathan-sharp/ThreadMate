<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ThreadMate.SettingsPage"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Settings"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Border Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="App Theme" FontAttributes="Bold" />
                    <Picker x:Name="ThemePicker"
                            Title="Select theme"
                            SelectedIndexChanged="OnThemeSelectedIndexChanged">
                        <Picker.Items>
                            <x:String>System</x:String>
                            <x:String>Light</x:String>
                            <x:String>Dark</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
