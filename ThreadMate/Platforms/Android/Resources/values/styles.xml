<?xml version="1.0" encoding="utf-8" ?>
<resources>
  <!-- Base theme for splash screen (required for Android 12+). -->
  <style name="Theme.SplashScreen" parent="Theme.MaterialComponents.NoActionBar">
    <item name="android:windowNoTitle">true</item>
    <item name="android:windowActionBar">false</item>
    <item name="android:windowFullscreen">false</item>
    <item name="android:windowDrawsSystemBarBackgrounds">true</item>
  </style>

  <!-- Base theme for the application. -->
  <style name="Maui.SplashTheme" parent="Theme.SplashScreen">
    <item name="android:windowSplashScreenAnimatedIcon">@drawable/maui_splash</item>
    <item name="android:windowSplashScreenIconBackgroundColor">@color/colorPrimary</item>
    <item name="android:windowSplashScreenBackground">@color/colorPrimary</item>
  </style>

  <style name="MainTheme" parent="Maui.MainTheme.NoActionBar">
    <item name="android:windowLightStatusBar">true</item>
    <item name="android:windowLightNavigationBar">true</item>
  </style>
</resources>
